*.tsbuildinfo
packages/*/*.tsbuildinfo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Test and browser tooling output
.playwright-mcp/
playwright-report/
test-results/
coverage/

# Package manager caches
.npm/
.pnpm-store/
.yarn/

# OS and editor files
.DS_Store
Thumbs.db
.idea/
.vscode/

# Local package archives
*.tgz
